# App
APP_NAME=bypur-api
APP_VERSION=1.0.0
APP_ENV=development

# Server
SERVER_PORT=3001
SERVER_API_URL=http://localhost:3001
SERVER_CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# Database
DB_URL=postgresql://postgres:[password]@localhost:5432/postgres?sslmode=disable
DB_DIRECT_URL=postgresql://postgres:[password]@localhost:5432/postgres?sslmode=disable

# JWT
JWT_SECRET=your_secure_jwt_secret_key_32_bytes_min
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Storage (Cloudflare R2)
STORAGE_ENABLED=false
STORAGE_ACCOUNT_ID=your_cloudflare_account_id
STORAGE_ACCESS_KEY_ID=your_r2_access_key_id
STORAGE_ACCESS_KEY_SECRET=your_r2_secret_access_key
STORAGE_BUCKET_NAME=your_bucket_name
STORAGE_PUBLIC_URL=https://your_bucket_name.your_account_id.r2.cloudflarestorage.com

# Mail (SMTP)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@bayu-apps.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=logs

# Frontend URLs
FRONTEND_PORTFOLIO_URL=http://localhost:3000
FRONTEND_CMS_URL=http://localhost:3002

# Features
FEATURE_STORAGE=false
FEATURE_EMAIL=false

# Security
SECURITY_X_API_KEY=bypur-default-public-api-key-2026
