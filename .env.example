# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=bypur-api
APP_VERSION=1.0.0
ENV=development

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
API_URL=http://localhost:3001

# =============================================================================
# DATABASE CONFIGURATION (Supabase / Postgres)
# =============================================================================
DATABASE_URL=postgresql://postgres:[password]@localhost:5432/postgres?sslmode=disable

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION
# =============================================================================
JWT_SECRET=your_secure_jwt_secret_key_32_bytes_min
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# =============================================================================
# CLOUDFLARE R2 STORAGE CONFIGURATION
# =============================================================================
R2_ENABLED=true
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_ACCESS_KEY_SECRET=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your_bucket_name.your_account_id.r2.cloudflarestorage.com

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@bayu-apps.com

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# =============================================================================
# FRONTEND URLS
# =============================================================================
PORTFOLIO_URL=http://localhost:3000
CMS_URL=http://localhost:3002

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_STORAGE=true
FEATURE_EMAIL=false

# =============================================================================
# PUBLIC API SECURITY KEY
# =============================================================================
X_API_KEY=bypur-default-public-api-key-2026
